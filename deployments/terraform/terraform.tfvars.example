# Copy thanh terraform.tfvars -- KHONG commit len git
# Chi chua config KHONG nhay cam. Secrets truyen qua -var tu .env (xem init.sh).

project     = "hivemind"
environment = "dev"
aws_region  = "ap-southeast-1"

services  = ["agent-worker", "scoring-api", "dispatcher", "reaper"]
image_tag = "latest"

bedrock_model_id           = "anthropic.claude-3-haiku-20240307-v1:0"
bedrock_embedding_model_id = "amazon.titan-embed-text-v2:0"
bedrock_embedding_region   = "us-east-1"

agent_worker_timeout_seconds      = 20
agent_worker_reserved_concurrency = 20
reaper_stuck_threshold_seconds    = 60

dispatcher_batch_size         = 100
dispatcher_max_worker_invokes = 20
memory_top_k                  = 3

risk_low_threshold  = 0.001
risk_high_threshold = 0.999

# Bat len 0.5 chi khi quay video demo self-healing
chaos_kill_rate = 0

schedules_enabled = true

scoring_api_url_auth_type = "AWS_IAM"

alert_email           = "your@email.com"
billing_threshold_usd = 50
