# AWS 
# AWS_PROFILE=hivemind
AWS_DEFAULT_REGION=ap-southeast-1
AWS_REGION_BEDROCK=ap-southeast-1
AWS_REGION_EMBED=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=



# CockroachDB secrets
DATABASE_URL="postgresql://user:pass@cluster.crdb.io:26257/hivemind?sslmode=verify-full"
COCKROACHDB_MCP_ENDPOINT=
COCKROACHDB_MCP_API_KEY=
COCKROACHDB_CLUSTER_ID=
COCKROACHDB_DATABASE=hivemind
MCP_TIMEOUT_SECONDS=

# LLM Model IDs
TITAN_MODEL_ID  = ""
CLAUDE_MODEL_ID = ""

# Worker / Reaper tuning
WORKER_POLL_INTERVAL_SECONDS=2
REAPER_STUCK_THRESHOLD_SECONDS=30

# Scoring API (Go -> Python bridge)
PYTHON_SCORING_ENDPOINT=http://localhost:8001/score
PORT=8080